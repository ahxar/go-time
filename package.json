{
  "name": "@ahxar/go-time",
  "version": "1.1.1",
  "description": "Go time-inspired API for Node.js with zero runtime dependencies",
  "keywords": [
    "duration",
    "go-time",
    "golang",
    "time",
    "timezone"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahxar/go-time.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.3",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.8.3",
    "vitest": "^4.0.7"
  },
  "engines": {
    "node": ">=20"
  }
}
