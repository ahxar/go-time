{
  "name": "@ahxar/go-time",
  "version": "1.1.5",
  "description": "Go time-inspired API for Node.js with zero runtime dependencies",
  "keywords": [
    "duration",
    "go-time",
    "golang",
    "time",
    "timezone"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahxar/go-time.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest run",
    "example:duration": "tsx examples/01-duration.ts",
    "example:time": "tsx examples/02-time.ts",
    "example:location": "tsx examples/03-location.ts",
    "example:timer": "tsx examples/04-timer.ts",
    "example:full": "tsx examples/full.ts"
  },
  "devDependencies": {
    "@emnapi/runtime": "^1.9.2",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.3",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=20"
  }
}
